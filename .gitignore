# builder writes alongside them (static asset dirs, etc.).
docs/_build/gettext/*
!docs/_build/gettext/*.pot

# tsdoc generation results
docs/scripting-doc/out/
docs/scripting-doc/node_modules

# Work-in-progress worktrees
wip/

