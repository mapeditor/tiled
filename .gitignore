# clangd cache
.cache/
compile_commands.json

# Mac stuff
*.DS_Store

# Qt Creator
*.user*
*.creator.*
*.autosave
build/ 

# Visual Studio
.vscode/
*.sln
*.suo
*.vcxproj
*.vcxproj.*
*.ncb
